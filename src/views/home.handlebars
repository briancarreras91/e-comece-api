<h1 class="mb-4">Catálogo de productos</h1>

<div class="row productos">
  {{#each payload}}
    <div class="col-md-4 mb-4">
      <div class="card h-100">
        <img
          src="{{this.thumbnail}}"
          class="card-img-top"
          alt="{{this.title}}"
        />
        <div class="card-body text-dark">
          <h5 class="card-title">{{this.title}}</h5>
          <p class="card-text">${{this.price}}</p>
          <p class="card-text">{{this.description}}</p>
          <p class="card-text"><strong>Categoría:</strong> {{this.category}}</p>
          <p class="card-text"><strong>Stock:</strong> {{this.stock}}</p>

          <!-- Botón para agregar al carrito -->
          <form action="/api/carts/{{../cartId}}/products/{{this._id}}" method="POST">
            <button type="submit" class="btn btn-primary">Agregar al carrito</button>
          </form>
        </div>
      </div>
    </div>
  {{/each}}
</div>

<!-- Paginación -->
<div class="pagination mt-4 d-flex justify-content-between">
  {{#if hasPrevPage}}
    <a href="{{prevLink}}" class="btn btn-secondary">Anterior</a>
  {{else}}
    <span></span>
  {{/if}}

  <span>Página {{page}} de {{totalPages}}</span>

  {{#if hasNextPage}}
    <a href="{{nextLink}}" class="btn btn-secondary">Siguiente</a>
  {{else}}
    <span></span>
  {{/if}}
</div>
