<div class="container mt-4">
  <h2 class="mb-4">Catálogo de Productos</h2>

  <!-- Filtros dinámicos de categorías -->
  {{#if categories}}
    <div class="mb-3">
      <label class="form-label">Filtrar por categoría:</label>
      <div class="d-flex flex-wrap gap-2">
        {{#each categories}}
          <a href="/products?category={{this}}" 
             class="btn btn-outline-primary btn-sm">
            {{this}}
          </a>
        {{/each}}
      </div>
    </div>
  {{/if}}

  <!-- Orden por precio -->
  <div class="mb-3">
    <a href="/products?sort=asc" class="btn btn-outline-secondary btn-sm">Precio ↑</a>
    <a href="/products?sort=desc" class="btn btn-outline-secondary btn-sm">Precio ↓</a>
  </div>

  {{#if payload.length}}
    <div class="row">
      {{#each payload}}
        <div class="col-md-4 mb-4">
          <div class="card h-100 d-flex flex-column">
            {{#if this.thumbnail}}
              <img src="{{this.thumbnail}}" 
                   class="card-img-top img-fluid" 
                   style="max-height:200px; object-fit:cover;" 
                   alt="{{this.title}}" />
            {{/if}}
            <div class="card-body flex-grow-1">
              <h5 class="card-title">{{this.title}}</h5>
              <p class="card-text">{{this.description}}</p>
              <p><strong>Precio:</strong> ${{this.price}}</p>
              <p><strong>Stock:</strong> {{this.stock}}</p>
              <p><strong>Categoría:</strong> {{this.category}}</p>
            </div>
            <div class="card-footer text-center">
              <form action="/api/carts/{{../cartId}}/products/{{this._id}}" method="POST" class="d-flex justify-content-center align-items-center gap-2">
                <input type="number" 
                       name="quantity" 
                       value="1" 
                       min="1" 
                       max="{{this.stock}}" 
                       class="form-control form-control-sm" 
                       style="width:80px;" />
                <button type="submit" class="btn btn-success btn-sm">Agregar al carrito</button>
              </form>
            </div>
          </div>
        </div>
      {{/each}}
    </div>

    <!-- Paginación -->
    <nav aria-label="Page navigation" class="mt-4">
      <ul class="pagination justify-content-center">
        {{#if (gt page 1)}}
          <li class="page-item">
            <a class="page-link" href="/products?page={{subtract page 1}}">Anterior</a>
          </li>
        {{/if}}
        {{#each (range 1 totalPages)}}
          <li class="page-item {{#if (eq this ../page)}}active{{/if}}">
            <a class="page-link" href="/products?page={{this}}">{{this}}</a>
          </li>
        {{/each}}
        {{#if (lt page totalPages)}}
          <li class="page-item">
            <a class="page-link" href="/products?page={{add page 1}}">Siguiente</a>
          </li>
        {{/if}}
      </ul>
    </nav>

  {{else}}
    <div class="alert alert-info">No hay productos disponibles</div>
  {{/if}}
</div>
