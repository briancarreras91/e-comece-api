<div class="container mt-5">
  {{#if error}}
    <div class="alert alert-danger text-center">
      <h4>{{error}}</h4>
      <p>Por favor, agregue productos antes de finalizar la compra.</p>
    </div>
  {{else}}
    {{#if message}}
      <!-- Mensaje de agradecimiento -->
      <div class="text-center">
        <img
          src="/assets/imagenes/Logo.png"
          alt="Logo ESK-bio"
          style="max-height:100px;"
          class="mb-3"
        />
        <div class="alert alert-success">
          <h4>{{message}}</h4>
          <p>Orden ID: <strong>{{orderId}}</strong></p>
        </div>
      </div>
    {{else}}
      {{#if products.length}}
        <!-- Resumen de compra -->
        <div class="alert alert-info">
          <h4>Resumen de la compra</h4>
          <p>Orden ID: <strong>{{orderId}}</strong></p>
        </div>

        <div class="card mt-4">
          <div class="card-body">
            <h5 class="card-title">Productos</h5>
            <ul class="list-group list-group-flush">
              {{#each products}}
                <li class="list-group-item">
                  {{this.product.title}}
                  - Cantidad:
                  {{this.quantity}}
                  - Subtotal: ${{multiply this.product.price this.quantity}}
                </li>
              {{/each}}
            </ul>
            <div class="mt-3">
              <h4>Total: ${{total}}</h4>
            </div>
          </div>
        </div>

        <!-- Botón de confirmación -->
        <div class="mt-4 text-center">
          <form action="/checkout/{{cartId}}/confirm" method="POST">
            <button type="submit" class="btn btn-primary btn-lg">Confirmar
              Compra</button>
          </form>
        </div>
      {{else}}
        <!-- Carrito vacío -->
        <div class="alert alert-warning text-center">
          <h4>El carrito está vacío</h4>
          <p>No hay productos para finalizar la compra.</p>
        </div>
      {{/if}}
    {{/if}}

    <!-- Botón para volver al catálogo -->
    <div class="mt-4 text-center">
      <a href="/products" class="btn btn-secondary">Volver al catálogo</a>
    </div>
  {{/if}}
</div>